# Read by `docker compose` itself for ${HF_TOKEN} substitution in
# docker-compose.yml (separate from Server/.env, which configures the app).
# Copy this to ".env" in the repo root and fill in a real token to enable
# speaker diarization (Phase 3):
#
#   1. Create a free account at https://huggingface.co
#   2. Accept the model terms at
#      https://huggingface.co/pyannote/speaker-diarization-3.1
#      (and its dependency, https://huggingface.co/pyannote/segmentation-3.0)
#   3. Generate an access token at https://huggingface.co/settings/tokens
#
# Without this, uploads still transcribe fine -- diarization just fails
# with a clear "HF_TOKEN is not set" error instead of a name/speaker label.
HF_TOKEN=

# Read by `docker compose` for ${ANTHROPIC_API_KEY} substitution above
# (separate from Server/.env, which configures the app). Enables AI
# meeting summaries (Phase 4):
#
#   1. Create an account at https://console.anthropic.com
#   2. Generate an API key at https://console.anthropic.com/settings/keys
#
# NEVER commit a real key here or anywhere else -- this file is checked
# into git as a template; only your local, un-committed ".env" should ever
# hold the real value. Without it, transcription and diarization still
# work fine -- summarization just fails with a clear "ANTHROPIC_API_KEY is
# not set" error instead of a summary.
ANTHROPIC_API_KEY=
