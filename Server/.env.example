# These values are for running the backend directly on your host (e.g. `uvicorn
# app.main:app --reload`) while Postgres/MinIO/Redis still run via `docker
# compose up -d postgres minio redis`. Use the *host-mapped* ports from
# docker-compose.yml, not the in-network service names ("postgres"/"minio"/
# "redis") -- those only resolve from inside the Docker network, i.e. from the
# `api`/`worker` containers themselves, which get their own config from the
# `environment:` block in docker-compose.yml, not from this file.

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# Database (5433 is docker-compose's host-mapped port for the postgres service)
DATABASE_URL=postgresql+psycopg2://voxintel:voxintel@localhost:5433/voxintel

# Auth
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Auth rate limiting
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Object storage (MinIO in dev)
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=voxintel
STORAGE_SECRET_KEY=voxintel123
STORAGE_BUCKET=voxintel-meetings
STORAGE_REGION=us-east-1
STORAGE_SECURE=false

# Upload limits
MAX_UPLOAD_SIZE_BYTES=524288000

# Background processing (6379 is docker-compose's host-mapped port for redis)
REDIS_URL=redis://localhost:6379/0

# Speech-to-text (worker-only; harmless for the API process to know about)
WHISPER_MODEL_SIZE=base

# Speaker diarization (worker-only). pyannote/speaker-diarization-3.1 is
# gated on Hugging Face -- see the root .env.example for the setup steps.
HF_TOKEN=
PYANNOTE_PIPELINE_NAME=pyannote/speaker-diarization-3.1
